@model FavoriteProductIndexViewModel
@{
    ViewData["Title"] = "喜好清單";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">我的喜好金融商品清單</h1>
    <a asp-controller="FavoriteProduct" asp-action="Create" class="btn btn-primary">+ 新增喜好商品</a>
</div>

<div class="card mb-4">
    <div class="card-body">
        <div class="row">
            <div class="col-sm-4"><strong>使用者：</strong>@Model.UserName</div>
            <div class="col-sm-4"><strong>扣款帳號：</strong>@Model.Account</div>
            <div class="col-sm-4"><strong>聯絡Email：</strong>@Model.Email</div>
        </div>
    </div>
</div>

@if (Model.Items.Count == 0)
{
    <p class="text-muted">目前沒有任何喜好金融商品，點選右上角「新增喜好商品」開始建立。</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th>產品名稱</th>
                    <th class="text-end">價格</th>
                    <th class="text-end">手續費率</th>
                    <th class="text-end">購買數量</th>
                    <th class="text-end">預計扣款總金額</th>
                    <th class="text-end">總手續費用</th>
                    <th class="text-end">操作</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@item.ProductName</td>
                        <td class="text-end">@item.Price.ToString("N2")</td>
                        <td class="text-end">@item.FeeRate.ToString("P2")</td>
                        <td class="text-end">@item.Qty</td>
                        <td class="text-end">@item.TotalAmount.ToString("N2")</td>
                        <td class="text-end">@item.TotalFee.ToString("N2")</td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-sn="@item.Sn" class="btn btn-sm btn-outline-secondary">編輯</a>
                            <a asp-action="Delete" asp-route-sn="@item.Sn" class="btn btn-sm btn-outline-danger">刪除</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
